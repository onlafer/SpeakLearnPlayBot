# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_NAME=speaklearnplaybot

# BotConfig
BOT_TOKEN=
ADMIN_LIST='[]'

# Хранилище файлов (локальная папка, бесплатно)
STORAGE_PATH=storage

# Скачивание больших файлов (>20 MB) через аккаунт пользователя (Telethon)
# Получить: https://my.telegram.org/apps
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_DOWNLOAD_CHAT_ID=@channel или -1001234567890

# GigaChat
GIGACHAT_CREDENTIALS=
